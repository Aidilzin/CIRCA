# ==============================================================================
# CIRCA Project .gitignore (Production-Ready)
# ==============================================================================

# 1. Local Environments & Secrets
.env
.env.*
.env.local
config.json
secrets.json

# 2. Python Virtual Environments
.venv/
venv/
env/
ENV/

# 3. Python Runtime & Compilation Caches
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# 4. Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 5. IDEs and Editor Configuration
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# 6. Datasets, Model Weights, & AI Artifacts
# Avoid pushing massive files and binary weights to GitHub (bloating)
datasets/
runs/
OLD-runs/
wandb/
weights/
*.pt
*.onnx
*.engine
*.pb
*.h5
*.hdf5
*.keras
*.xml
*.bin

# 7. Archives and Zip Packages
*.zip
*.tar.gz
*.rar
*.7z

# 8. Temporary Output Files & Run Logs
*.log
crash_report.log
execution_trace.log
training.log
log/
*_output.txt
test_results.txt
test_output_utf8.txt

# 9. Jupyter Notebook Checkpoints
.ipynb_checkpoints/

# 10. AI Agent Workspaces & Conversation Transcripts
.antigravitycli/
.claude/
.gemini/
**/skills/
restored_conversations_history.md

# 11. Legacy and Backups
.OLD/

# 12. Deployment Staging & Local Script Exclusions
# These scripts are local-only helpers or deployment packages
requirements_runpod.txt
scripts/core/upload-to-runpod.py
scripts/archive/generate-thesis-plots.py
scripts/archive/convert-markdown-thesis-to-docx.py
scripts/core/setup-runpod-environment.sh
scripts/core/upload-offline-wandb-metrics.py

# Intermediate/dev docs not needed in repo
docs/circa_progress_report_presentation.html
docs/circa_research_framework.html
docs/hpo_analysis.md
docs/phase1_comparison.md
docs/phase1_vs_phase2_ablation.md
docs/quantization_results.json
docs/CIRCA_EXPERIMENT_CHECKLIST.md
docs/CIRCA_EXPERIMENT_PLAN.md
docs/CIRCA_HYPERPARAMETER_TUNING.md
docs/CIRCA_TRAIN_ENGINE_GUIDE.md
docs/CIRCA_DATASET_PREPROCESSING.md
docs/CSP650_*.pdf
docs/Thesis_Formatting*.pdf
docs/Chapter_4_Results_and_Findings.pdf
docs/CIRCA_THESIS_CH1_4.md
docs/references_pdf/
# DOCX/PDF thesis builds (binary, dynamically compiled from Markdown source)
docs/*.docx
docs/*.pdf